# 2. Check if today matches a birthday in the birthdays.csv

dt = dt.datetime.now()
year = dt.year
month = dt.month
day = dt.day

for birthday in birthday_list:
    if birthday['month'] == month and birthday['day'] == day:
        with open(f"letter_templates/letter_{random.randint(1, 3)}.txt") as f:
            letter_template = f.read()
            try:
                letter_template = letter_template.replace("[NAME]", birthday['name'])
            except KeyError:
                letter_template = f"Happy birthday {birthday['name']}!!"

            smtp = ""
            if "gmail.com" in birthday['email']:
                smtp = "smtp.gmail.com"
            elif "yahoo.com" in birthday['email'] or "yahoo.co.in" in birthday['email']:
                smtp = "smtp.mail.yahoo.com"
            else:
                smtp = None
            print(letter_template)
            with smtplib.SMTP(smtp, 587) as connection:
                connection.starttls()
                connection.login(my_email, my_pass)
                connection.sendmail(my_email, birthday['email'], f"Subject: Happy birthday wish!\n\n{letter_template}")


